.nav-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--paper, #F2EFE8);
}

.nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

/* Left capsule - matches system capsule style */
.nav-capsule {
  position: fixed;
  left: 16rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(0, 0, 0, 0.15);
  border-radius: 100rpx;
  background: rgba(0, 0, 0, 0.05);
  overflow: hidden;
  z-index: 101;
}

.nav-capsule-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.nav-capsule-divider {
  width: 1rpx;
  height: 60%;
  background: rgba(0, 0, 0, 0.15);
}

/* Back arrow */
.arrow-left {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid var(--ink, #2B2925);
  border-bottom: 4rpx solid var(--ink, #2B2925);
  transform: rotate(45deg);
  margin-left: 6rpx;
}

/* Home icon */
.home-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.home-roof {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 10rpx solid var(--ink, #2B2925);
}

.home-body {
  width: 14rpx;
  height: 10rpx;
  border: 3rpx solid var(--ink, #2B2925);
  border-top: none;
  margin-top: -1rpx;
}

/* Title area */
.nav-title-area {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  pointer-events: none;
}

.nav-logo {
  width: 48rpx;
  height: 48rpx;
  background: var(--seal, #A4543B);
  color: #fff;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-family: "Songti SC", serif;
  transform: rotate(-3deg);
  flex-shrink: 0;
}

.nav-title-wrap {
  display: flex;
  flex-direction: column;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.nav-subtitle {
  font-size: 20rpx;
  color: var(--muted, #8C857A);
}

@media (prefers-color-scheme: dark) {
  .nav-capsule {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.1);
  }

  .nav-capsule-divider {
    background: rgba(255, 255, 255, 0.2);
  }
}
