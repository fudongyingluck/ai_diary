.tab-bar {
  display: flex;
  align-items: flex-end;
  height: 110rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(251, 249, 244, 0.96);
  border-top: 1rpx solid var(--line, #DAD4C8);
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

@media (prefers-color-scheme: dark) {
  .tab-bar {
    background: rgba(28, 26, 23, 0.96);
  }
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
}

.tab-text {
  font-size: 24rpx;
  color: var(--muted, #8C857A);
  letter-spacing: 2rpx;
}

.tab-item.active .tab-text {
  color: var(--ink, #2B2925);
  font-weight: 600;
}

.tab-item.center {
  position: relative;
}

.center-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--seal, #A4543B);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
  box-shadow: 0 8rpx 24rpx rgba(164, 84, 59, 0.35);
}

.center-icon {
  color: #fff;
  font-size: 36rpx;
}
