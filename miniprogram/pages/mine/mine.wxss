.page {
  min-height: 100vh;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.stat-card {
  flex: 1;
  background: var(--card);
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--seal);
}

.stat-label {
  font-size: 22rpx;
  color: var(--muted);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: var(--card);
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.menu-arrow {
  color: var(--muted);
  font-size: 28rpx;
}

.about-text {
  font-size: 26rpx;
  padding: 12rpx 0;
}

.about-text.muted {
  color: var(--muted);
  font-size: 24rpx;
}
