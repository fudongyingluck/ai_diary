.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.time-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.clear-time {
  color: var(--muted);
  font-size: 24rpx;
  padding: 8rpx;
}

.mood-row {
  display: flex;
  justify-content: space-between;
}

.mood-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 2rpx solid var(--line);
  background: var(--card);
  justify-content: center;
}

.mood-btn.active {
  background: var(--ink);
  border-color: var(--ink);
}

.mood-emoji {
  font-size: 36rpx;
}

.mood-label {
  font-size: 18rpx;
  color: var(--muted);
}

.mood-btn.active .mood-label {
  color: var(--paper);
}

.content-wrap {
  position: relative;
}

.content-input {
  width: 100%;
  min-height: 240rpx;
  border: 2rpx solid var(--line);
  background: var(--card);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--ink);
  box-sizing: border-box;
}

.content-count {
  position: absolute;
  right: 16rpx;
  bottom: 12rpx;
  font-size: 20rpx;
  color: var(--muted);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-btn {
  font-size: 24rpx;
  padding: 14rpx 24rpx;
  border-radius: 32rpx;
  background: var(--card);
  border: 2rpx solid var(--line);
  color: var(--ink);
}

.tag-btn.active {
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
}

.tag-btn.add-tag {
  border-style: dashed;
  color: var(--muted);
}

.param-section {
  background: var(--card);
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.param-tag-name {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}

.param-row {
  margin-top: 12rpx;
}

.param-label {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
  display: block;
}

.param-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.param-input {
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  background: var(--paper);
  color: var(--ink);
}

.param-input.number {
  width: 120rpx;
  text-align: center;
}

.param-number-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.param-unit {
  font-size: 24rpx;
  color: var(--muted);
}

.save-area {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}
