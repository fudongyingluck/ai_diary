.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.form-input {
  border: 2rpx solid var(--line);
  background: var(--card);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--ink);
  margin-bottom: 8rpx;
}

.icon-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.icon-option {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 12rpx;
  border: 2rpx solid var(--line);
  background: var(--card);
}

.icon-option.active {
  border-color: var(--seal);
  background: rgba(164, 84, 59, 0.1);
}

.form-input.small {
  padding: 14rpx 20rpx;
  font-size: 26rpx;
}

.param-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--card);
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.param-remove {
  color: var(--seal);
  padding: 8rpx;
  font-size: 24rpx;
}

.add-param-form {
  background: var(--card);
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--muted);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.param-actions {
  display: flex;
  gap: 24rpx;
  justify-content: flex-end;
  margin-top: 8rpx;
}

.param-action-btn {
  font-size: 26rpx;
  color: var(--seal);
  font-weight: 600;
}

.param-action-cancel {
  font-size: 26rpx;
  color: var(--muted);
}

.add-param-btn {
  border: 2rpx dashed var(--line);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--muted);
}

.save-area {
  margin-top: 48rpx;
}
