.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.tag-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: var(--card);
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.tag-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tag-icon {
  font-size: 36rpx;
}

.tag-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}

.tag-params {
  font-size: 22rpx;
  color: var(--muted);
}

.delete-btn {
  font-size: 24rpx;
  color: var(--seal);
  padding: 8rpx 16rpx;
}

.add-btn {
  border: 2rpx dashed var(--line);
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--muted);
  margin-top: 16rpx;
}
