.page {
  min-height: 100vh;
}

/* Calendar */
.calendar {
  padding: 16rpx 32rpx 24rpx;
}

.cal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.cal-title {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.cal-arrow {
  font-size: 28rpx;
  color: var(--muted);
  padding: 8rpx 20rpx;
}

.cal-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 8rpx;
}

.cal-wd {
  font-size: 22rpx;
  color: var(--muted);
  padding: 8rpx 0;
}

.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.cal-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  position: relative;
}

.cal-day-num {
  font-size: 24rpx;
}

.cal-day.out {
  opacity: 0.3;
}

.cal-day.today {
  background: var(--ink);
  color: var(--paper);
}

.cal-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-top: 4rpx;
}

/* Recent entries */
.entry-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.entry-date {
  font-size: 24rpx;
  font-weight: 600;
}

.entry-mood {
  font-size: 28rpx;
}

.entry-body {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--ink);
  margin-bottom: 12rpx;
  word-break: break-all;
}

.entry-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.frag-divider {
  height: 1rpx;
  background: var(--line);
  margin: 16rpx 0;
}

.empty-hint {
  text-align: center;
  color: var(--muted);
  font-size: 26rpx;
  padding: 60rpx 0;
}
